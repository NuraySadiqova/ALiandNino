@model AliAndNinoClone.Models.ViewModels.LoginVM

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4 border p-4 shadow-sm rounded bg-white">
            <h2 class="text-center text-danger mb-4">Giriş</h2>
            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                <div class="mb-3">
                    <label class="form-label">İstifadəçi adı və ya Email</label>
                    <input asp-for="UsernameOrEmail" class="form-control" />
                    <span asp-validation-for="UsernameOrEmail" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Şifrə</label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label class="form-check-label">Məni yadda saxla</label>
                </div>

                <button type="submit" class="btn btn-danger w-100 mt-2">Daxil Ol</button>

                <div class="text-center mt-3">
                    <small>Hesabınız yoxdur? <a asp-action="Register" class="text-danger">Qeydiyyatdan keçin</a></small>
                </div>
            </form>
        </div>
    </div>
</div>