@model AliAndNinoClone.Models.ViewModels.CheckoutVM

<div class="container mt-5">
    <div class="row">
        <div class="col-md-7">
            <div class="card shadow-sm border-0 p-4">
                <h3 class="mb-4 text-danger border-bottom pb-2">Çatdırılma Məlumatları</h3>

                <form asp-action="Checkout" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label fw-bold">Tam Ünvan</label>
                        <textarea asp-for="Address" class="form-control" rows="3" placeholder="Məs: Bakı ş., Yasamal r., Nizami küç. 45..."></textarea>
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="PhoneNumber" class="form-label fw-bold">Əlaqə Nömrəsi</label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="050-XXX-XX-XX" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-danger btn-lg w-100 shadow">
                        <i class="fa-solid fa-check-circle me-2"></i> Sifarişi Tamamla
                    </button>

                    <a asp-controller="Basket" asp-action="Index" class="btn btn-link w-100 mt-2 text-muted text-decoration-none">
                        <i class="fa-solid fa-arrow-left small"></i> Səbətə qayıt
                    </a>
                </form>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm border-0 bg-light p-4">
                <h4 class="mb-4">Sifarişin Xülasəsi</h4>

                <div class="checkout-items overflow-auto" style="max-height: 400px;">
                    @foreach (var item in Model.BasketItems)
                    {
                        <div class="d-flex align-items-center mb-3 border-bottom pb-2">
                            <img src="@item.Book.ImageUrl" alt="@item.Book.Title" style="width: 50px; height: 70px; object-fit: contain;" class="me-3 rounded shadow-sm">
                            <div class="flex-grow-1">
                                <h6 class="mb-0 text-truncate" style="max-width: 200px;">@item.Book.Title</h6>
                                <small class="text-muted">Say: @item.Count ədəd</small>
                            </div>
                            <div class="text-end">
                                <span class="fw-bold">@(item.Count* item.Book.Price) AZN</span>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-4 pt-3 border-top">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="h5">Cəmi Ödəniləcək:</span>
                        <span class="h4 text-danger fw-bold">@Model.TotalPrice AZN</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}