@model AliAndNinoClone.Models.Basket.Basket


    @if (Model.BasketItems != null && Model.BasketItems.Any())
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Şəkil</th>
                        <th>Kitab</th>
                        <th>Qiymət</th>
                        <th>Sayı</th>
                        <th>Cəmi Məbləğ</th>
                        <th>Əməliyyat</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.BasketItems)
                    {
                        <tr>
                            <td>
                                <img src="~/Assets/Images/@item." alt="@item.Book.Title" style="width: 50px; height: 70px; object-fit: cover; border-radius: 4px;" />
                            </td>
                            <td class="fw-bold">@item.Book.Title</td>
                            <td>@item.Book.Price AZN</td>

                            <td>
                                <div class="d-flex align-items-center">
                                    <a asp-controller="Basket" asp-action="DecreaseQuantity" asp-route-id="@item.BookId" class="btn btn-sm btn-outline-secondary fw-bold px-2 py-0 fs-5">-</a>

                                    <span class="mx-3 fw-bold fs-5">@item.Count</span>

                                    <a asp-controller="Basket" asp-action="IncreaseQuantity" asp-route-id="@item.BookId" class="btn btn-sm btn-outline-secondary fw-bold px-2 py-0 fs-5">+</a>
                                </div>
                            </td>
                            <td class="text-primary fw-bold">@(item.Count* item.Book.Price) AZN</td>
                            <td>
                                <a asp-controller="Basket"
                                   asp-action="RemoveFromBasket"
                                   asp-route-id="@item.BookId"
                                   class="btn btn-sm btn-outline-danger">
                                    <i class="fa-solid fa-trash"></i> Sil
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-end mt-4">
            <div class="p-4 border rounded bg-light shadow-sm" style="min-width: 300px;">
                <h4 class="mb-3 d-flex justify-content-between">
                    <span>Ümumi:</span>
                    <span class="text-success fw-bold">@Model.BasketItems.Sum(x => x.Count * x.Book.Price) AZN</span>
                </h4>
                <button class="btn btn-success w-100 fw-bold">Sifarişi Təsdiqlə</button>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center py-5 shadow-sm">
            <i class="fa-solid fa-basket-shopping fa-3x mb-3 text-muted"></i>
            <h4>Səbətiniz hazırda boşdur</h4>
            <p class="text-muted">Görünür hələ heç bir kitab seçməmisiniz. Mağazaya qayıdıb kitabları incələyə bilərsiniz.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-danger mt-3 px-4 py-2">Mağazaya Qayıt</a>
        </div>
    }
</div>
