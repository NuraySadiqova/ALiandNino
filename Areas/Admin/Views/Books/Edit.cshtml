@using AliAndNinoClone.ViewModels
@model BookEditVM

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Kitabı Redaktə Et: @Model.Title</h6>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" enctype="multipart/form-data">
                        @* --- GİZLİ SAHƏLƏR (Mütləqdir!) --- *@
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ExistingImageUrl" />

                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="row">
                            <div class="col-md-6 col-12 mb-3">
                                <label asp-for="Title" class="form-label font-weight-bold">Kitabın Adı</label>
                                <input asp-for="Title" class="form-control" />
                                <span asp-validation-for="Title" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 col-12 mb-3">
                                <label asp-for="Author" class="form-label font-weight-bold">Müəllif</label>
                                <input asp-for="Author" class="form-control" />
                                <span asp-validation-for="Author" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 col-12 mb-3">
                                <label asp-for="Price" class="form-label font-weight-bold">Qiymət (AZN)</label>
                                <input asp-for="Price" type="number" step="0.01" class="form-control" />
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 col-12 mb-3">
                                <label asp-for="StockCount" class="form-label font-weight-bold">Stok Sayı</label>
                                <input asp-for="StockCount" class="form-control" />
                                <span asp-validation-for="StockCount" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 col-12 mb-3">
                                <label asp-for="CategoryId" class="form-label font-weight-bold">Kateqoriya</label>
                                <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId">
                                    <option value="">-- Kateqoriya Seç --</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>
                        </div>

                        @* --- ŞƏKİL HİSSƏSİ --- *@
                        <div class="mb-4">
                            <label class="form-label font-weight-bold d-block">Kitab Şəkli</label>

                            @* Mövcud şəkli göstəririk *@
                            <div class="mb-3">
                                <p class="small text-muted mb-1">Hazırkı şəkil:</p>
                                <img src="~/Assets/Images/@Model.ExistingImageUrl"
                                     alt="Current Book Image"
                                     style="width: 120px; height: 160px; object-fit: cover; border: 1px solid #ddd; border-radius: 5px;" />
                            </div>

                            @* Yeni şəkil yükləmək üçün input *@
                            <div class="custom-file">
                                <input asp-for="Photo" type="file" class="custom-file-input" id="customFile" accept="image/*">
                                <label class="custom-file-label" for="customFile">Şəkli dəyişmək üçün yenisini seçin...</label>
                                <small class="form-text text-muted">Boş buraxsanız, köhnə şəkil qalacaq.</small>
                            </div>
                            <span asp-validation-for="Photo" class="text-danger small"></span>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary btn-icon-split">
                                <span class="text">Geri qayıt</span>
                            </a>
                            <button type="submit" class="btn btn-warning btn-icon-split text-white">
                                <span class="text">Dəyişiklikləri Yadda Saxla</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Seçilən faylın adını label-də göstərmək üçün
        $(".custom-file-input").on("change", function () {
            var fileName = $(this).val().split("\\").pop();
            $(this).siblings(".custom-file-label").addClass("selected").html(fileName);
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}