@model IEnumerable<AliAndNinoClone.Models.Book>

@{
    ViewData["Title"] = "Kitab İdarəetməsi";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Kitabların İdarə Edilməsi</h1>
        <a asp-action="Create" class="btn btn-sm btn-primary shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50"></i> Yeni Kitab Əlavə Et
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Bütün Kitabların Siyahısı</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="bookTable" width="100%" cellspacing="0">
                    <thead class="thead-light">
                        <tr>
                            <th style="width: 80px;">Şəkil</th>
                            <th>Kitab Adı</th>
                            <th>Müəllif</th>
                            <th>Qiymət</th>
                            <th>Kateqoriya</th>
                            <th class="text-center" style="width: 120px;">Əməliyyatlar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="~/Assets/Images/@item.ImageUrl" style="width:60px; height:80px; object-fit:cover; border-radius:4px; border: 1px solid #ddd;" />
                                    }
                                    else
                                    {
                                        <img src="~/Assets/Images/no-image.png" style="width:60px; height:80px; object-fit:cover; border-radius:4px;" />
                                    }
                                </td>
                                <td class="align-middle font-weight-bold">@item.Title</td>
                                <td class="align-middle">@item.Author</td>
                                <td class="align-middle">@item.Price AZN</td>
                                <td class="align-middle">
                                    @if (item.Category != null)
                                    {
                                        <span class="badge badge-info p-2">@item.Category.Name</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Kateqoriyasız</span>
                                    }
                                </td>
                                <td class="text-center align-middle">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm" title="Redaktə et">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button type="button" class="btn btn-danger btn-sm delete-btn"
                                                data-id="@item.Id"
                                                data-name="@item.Title"
                                                title="Sil">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @Html.AntiForgeryToken()
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Admin/vendor/datatables/jquery.dataTables.min.js"></script>
    <script src="~/Admin/vendor/datatables/dataTables.bootstrap4.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#bookTable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Azerbaijan.json" // Cədvəli azərbaycancaya çevirir
                }
            });
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            $('.delete-btn').click(function () {
                var id = $(this).data('id');
                var name = $(this).data('name');

                Swal.fire({
                    title: 'Əminsiniz?',
                    text: name + " tamamilə silinəcək!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Bəli, sil!',
                    cancelButtonText: 'Xeyr'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '/Admin/Books/Delete/' + id,
                            type: 'POST',
                            data: {
                                "__RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                            },
                            success: function () {
                                Swal.fire('Silindi!', 'Kitab uğurla silindi.', 'success')
                                    .then(() => { location.reload(); });
                            },
                            error: function () {
                                Swal.fire('Xəta!', 'Nəsə düz getmədi.', 'error');
                            }
                        });
                    }
                });
            });
        });
    </script>
}